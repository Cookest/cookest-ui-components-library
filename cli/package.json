{
  "name": "@cookest/ui-cli",
  "version": "0.1.1",
  "description": "CLI to add Cookest UI components to React and Flutter projects — shadcn-style",
  "license": "MIT",
  "author": "Cookest <hello@cookest.com>",
  "homepage": "https://github.com/Cookest/cookest-ui-components-library/tree/main/cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cookest/cookest-ui-components-library.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/Cookest/cookest-ui-components-library/issues"
  },
  "keywords": [
    "cookest",
    "ui",
    "components",
    "react",
    "flutter",
    "cli",
    "design-system",
    "tailwindcss",
    "shadcn"
